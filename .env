# Copy this file to .env and replace all example values.
# Do NOT commit real secrets.

# Shared secret expected by POST /jira/release-approval payload:
# payload.sharedSecret must match this value.
APP_SHARED_SECRET=replace-with-a-long-random-secret

# Slack app credentials (from https://api.slack.com/apps)
SLACK_SIGNING_SECRET=replace-with-your-slack-signing-secret
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Optional Slack app-level token
#Create this token under "Basic Information", App-Level Tokens, Generate Token and Scopes.
#This needs to have a scope of connections:write.  Generate token and put below.
SLACK_APP_TOKEN=

# Optional fallback channel for ack messages when payload has no channelId/response_url
SLACK_CHANNEL_ID=replace with the ID (not the name) of the slack channel you want notifications to go to.

# Server settings
PORT=3000
SQLITE_DB_PATH=./data/release_scheduler.db

# Optional defaults used to prefill /jira-config modal.
# Each Slack workspace can override these values in the modal.
APPROVAL_FIELD_ID=customfield_12345
APPROVED_TRANSITION_ID=31
DECLINED_TRANSITION_ID=41
